{
  "name": "litestar-website",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NODE_OPTIONS='--max-old-space-size=8192' nuxt build",
    "generate": "NODE_OPTIONS='--max-old-space-size=8192' nuxt generate",
    "generate-github": "NODE_OPTIONS='--max-old-space-size=8192' nuxt generate --preset github_pages",
    "generate-verbose": "NODE_OPTIONS='--max-old-space-size=8192' nuxt generate --logLevel=verbose",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "oxlint . --fix",
    "lint:check": "oxlint .",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "prek install || true",
    "test-unit": "npx vitest --project unit",
    "test-nuxt": "npx vitest --project nuxt",
    "test-all": "npx vitest",
    "update-stats": "npx tsx scripts/update-stats.ts"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.109",
    "@iconify-json/simple-icons": "^1.2.83",
    "@nuxt/content": "^3.14.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^1.1.1",
    "@nuxt/ui": "^4.8.0",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/html-validator": "^2.1.0",
    "@nuxtjs/mdc": "^0.22.0",
    "@nuxtjs/robots": "^6.0.8",
    "@nuxtjs/sitemap": "^8.0.15",
    "@takumi-rs/core": "^1.4.1",
    "@unhead/vue": "^3.1.0",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/node-toolbar": "^1.1.1",
    "@vue/compiler-sfc": "^3.5.34",
    "@vueuse/components": "^14.3.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "better-sqlite3": "^12.10.0",
    "motion-v": "^2.2.1",
    "nuxt": "^4.4.6",
    "nuxt-link-checker": "^5.0.10",
    "nuxt-og-image": "^6.5.1",
    "nuxt-schema-org": "^6.0.4",
    "remark-gfm": "^4.0.1",
    "scule": "^1.3.0",
    "sitemap": "^9.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "ufo": "^1.6.4",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@11.3.0",
  "devDependencies": {
    "@j178/prek": "^0.4.3",
    "@nuxt/test-utils": "^4.0.3",
    "@shikijs/transformers": "^4.1.0",
    "@vue/test-utils": "^2.4.10",
    "happy-dom": "^20.9.0",
    "nuxt-content-twoslash": "^0.4.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "shiki": "^4.1.0",
    "twoslash": "^0.3.8",
    "vitest": "^4.1.7"
  }
}
